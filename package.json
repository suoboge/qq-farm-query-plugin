{
  "name": "qq-farm-query-plugin",
  "plugin": "QQ农场查询插件",
  "version": "1.0.0",
  "type": "module",
  "main": "index.mjs",
  "description": "QQ农场状态查询插件 - 扫码登录、查看农场状态、背包物品、成熟时间等",
  "author": "鲁班",
  "license": "MIT",
  "keywords": [
    "napcat",
